# ── Subsonic / Navidrome server ──────────────────────────────
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=admin
NAVIDROME_PASSWORD=changeme

# ── Databases (paths inside the container) ───────────────────
ANALYSIS_DB_PATH=/data/analysis.db
VIBE_DB_PATH=/data/vibe.db

# ── LLM provider: ollama (default) | openai | anthropic ──────
VIBE_LLM_PROVIDER=ollama

# Ollama (local, default) — point at your Ollama host
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_THINK=false
OLLAMA_NUM_CTX=8192

# OpenAI-compatible (covers Open WebUI, OpenAI, LM Studio, etc.) — optional
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic Claude (cheap, no GPU) — optional fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── App ──────────────────────────────────────────────────────
VIBE_API_TOKEN=
VIBE_PORT=4546
